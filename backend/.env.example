# Application
# Для локальной разработки используйте SQLite (создаётся автоматически):
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# Для production переключитесь на PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/lifetrack
SECRET_KEY=change-me-in-production-use-256-bit-random
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM Config
# Для прямого облачного OpenAI:
OPENAI_API_KEY=sk-...
# Для сторонних совместимых прокси (например, n1618, OpenRouter и т.д.):
OPENAI_API_BASE=https://n1618.ru/api/v1

# Для работы через LiteLLM (можно дублировать ключи при необходимости)
# LITELLM_API_KEY=your-key
# LITELLM_API_BASE=https://your-base

LITELLM_MODEL=gpt-4o   # Поддерживаются любые модели (например: qwen/qwen3.5-flash-02-23, gpt-4o)
LITELLM_MAX_TOKENS=2048
LITELLM_TEMPERATURE=0.3

# Локальная модель Ollama (бесплатная альтернатива)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:2b

# Security
# Можно указать одним URL или через запятую для нескольких:
ALLOWED_ORIGINS=http://localhost:5173
